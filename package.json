{
  "name": "sandscape",
  "version": "2.0.0",
  "private": true,
  "description": "Gravity-responsive moving sand art — PWA and Capacitor mobile app",
  "type": "module",
  "scripts": {
    "start": "npx --yes http-server ./www -p 4173 -c-1",
    "serve": "npx --yes http-server ./www -p 4173 -c-1",
    "test": "node tests/run-tests.mjs",
